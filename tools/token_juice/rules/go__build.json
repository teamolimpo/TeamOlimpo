{
  "id": "go-build",
  "family": "go-build",
  "match": { "argv0": ["go"], "argv_includes": [["build"]] },
  "transforms": { "strip_ansi": true, "trim_empty_edges": true, "dedupe_adjacent": true },
  "filters": { "skip_patterns": ["^\\s*$"] },
  "summarize": { "head": 8, "tail": 5 },
  "counters": [{"name": "errors", "pattern": "cannot find|undefined:|expected"}],
  "failure": { "preserve_on_failure": true, "head": 12, "tail": 8 }
}