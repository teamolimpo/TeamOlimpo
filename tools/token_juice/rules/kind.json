{
  "id": "kind",
  "family": "kind",
  "match": { "argv0": ["kind"] },
  "transforms": { "strip_ansi": true, "trim_empty_edges": true },
  "filters": { "skip_patterns": ["^\\s*$", "Creating cluster"] },
  "summarize": { "head": 10, "tail": 5 },
  "counters": [{"name": "clusters", "pattern": "^[a-zA-Z][a-zA-Z0-9_-]+"}],
  "failure": { "preserve_on_failure": true, "head": 12, "tail": 8 }
}