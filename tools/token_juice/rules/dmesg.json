{
  "id": "dmesg",
  "family": "dmesg",
  "match": { "argv0": ["dmesg"] },
  "transforms": { "strip_ansi": true, "strip_timestamps": true, "trim_empty_edges": true, "dedupe_adjacent": true },
  "filters": { "skip_patterns": ["^\\s*$"] },
  "summarize": { "head": 15, "tail": 10 },
  "failure": { "preserve_on_failure": true, "head": 20, "tail": 10 }
}