{
  "id": "kubectl-logs",
  "family": "kubectl-logs",
  "match": { "argv0": ["kubectl"], "argv_includes": [["logs"]] },
  "transforms": { "strip_ansi": true, "strip_timestamps": true, "trim_empty_edges": true },
  "filters": { "skip_patterns": ["^\\s*$"] },
  "summarize": { "head": 15, "tail": 10 },
  "failure": { "preserve_on_failure": true, "head": 15, "tail": 10 }
}