{
  "id": "pnpm-install",
  "family": "pnpm-install",
  "match": { "argv0": ["pnpm"], "argv_includes": [["install"]] },
  "transforms": { "strip_ansi": true, "trim_empty_edges": true, "dedupe_adjacent": true },
  "filters": { "skip_patterns": ["^\\s*$", "^Packages:", "^Progress:", "^Resolving:", "^Lockfile"] },
  "summarize": { "head": 5, "tail": 3 },
  "counters": [{"name": "dependencies", "pattern": "^\\+\\s+"}],
  "failure": { "preserve_on_failure": true, "head": 10, "tail": 5 }
}