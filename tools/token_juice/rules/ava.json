{
  "id": "ava",
  "family": "test-ava",
  "match": { "argv0": ["ava", "npx"], "argv_includes": [["ava"]] },
  "transforms": { "strip_ansi": true, "trim_empty_edges": true },
  "filters": { "skip_patterns": ["^\\s*$"] },
  "summarize": { "head": 10, "tail": 5 },
  "counters": [{"name": "pass", "pattern": "✓"}, {"name": "fail", "pattern": "✗"}],
  "failure": { "preserve_on_failure": true, "head": 15, "tail": 10 }
}