{
  "id": "yarn-install",
  "family": "yarn-install",
  "match": { "argv0": ["yarn"], "argv_includes": [["install"]] },
  "transforms": { "strip_ansi": true, "trim_empty_edges": true, "dedupe_adjacent": true },
  "filters": { "skip_patterns": ["^\\s*$", "^yarn install v", "^\\[\\d+/\\d+\\]"] },
  "summarize": { "head": 5, "tail": 3 },
  "counters": [{"name": "saved", "pattern": "Saved \\d+"}],
  "failure": { "preserve_on_failure": true, "head": 10, "tail": 5 }
}