{
  "mcpServers": {
    "email_processor": {
      "command": "uv",
      "args": ["run", "python", "-m", "tools.email_processor.server"],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "taskmanager": {
      "command": "uv",
      "args": ["run", "python", "-m", "tools.taskmanager.server"],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    "session_memory": {
      "command": "uv",
      "args": ["run", "python", "-m", "tools.session_memory.server"],
      "env": {
        "PYTHONUNBUFFERED": "1",
        "SESSION_DB_PATH": "lib/System/Hermes/session.db"
      }
    },
    "executor": {
      "command": "uv",
      "args": ["run", "python", "-m", "tools.executor.server"],
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
